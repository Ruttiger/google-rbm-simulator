    {
      "name": "Get Access Token",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/x-www-form-urlencoded"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/token",
          "host": [
            "localhost"
          ],
          "port": "8080",
          "protocol": "http",
          "path": [
            "token"
          ]
        },
        "body": {
          "mode": "urlencoded",
          "urlencoded": [
            {
              "key": "grant_type",
              "value": "client_credentials",
              "type": "text"
            },
            {
              "key": "client_id",
              "value": "test",
              "type": "text"
            },
            {
              "key": "client_secret",
              "value": "test",
              "type": "text"
            }
          ]
        }
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status is 200\", function () { pm.response.to.have.status(200); });",
              "let data = pm.response.json();",
              "pm.expect(data).to.have.property(\"access_token\");",
              "pm.environment.set(\"ACCESS_TOKEN\", data.access_token);",
              "console.log(\"ACCESS_TOKEN almacenado.\");"
            ]
          }
        }
      ]
    },
