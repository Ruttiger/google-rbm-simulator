<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="WARN">
  <Appenders>
    <Console name="Console" target="SYSTEM_OUT">
      <PatternLayout pattern="%d{ISO8601} %-5p [%t] %c{1.} %X{correlationId} %X{traceId} %X{spanId} - %m%n"/>
    </Console>
  </Appenders>

  <Loggers>
    <Logger name="org.zalando.logbook" level="trace" additivity="false">
      <AppenderRef ref="Console"/>
    </Logger>

    <AsyncRoot level="${sys:LOG_LEVEL:-DEBUG}">
      <AppenderRef ref="Console"/>
    </AsyncRoot>
  </Loggers>
</Configuration>
